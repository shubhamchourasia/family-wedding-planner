generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  fullName  String
  role      UserRole  @default(FAMILY)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  weddings  Wedding[]
}

model Wedding {
  id            String              @id @default(cuid())
  title         String
  brideName     String
  groomName     String
  startDate     DateTime
  endDate       DateTime?
  ownerId       String
  overallBudget Float?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  description   String?
  location      String?
  budgetItems   BudgetItem[]
  budgetFields  BudgetCustomField[]
  documents     Document[]
  events        Event[]
  families      Family[]
  guests        Guest[]
  guestFields   GuestCustomField[]
  tasks         Task[]
  vendors       Vendor[]
  taskLists     TaskList[]
  owner         User                @relation(fields: [ownerId], references: [id])
}

model Family {
  id         String   @id @default(cuid())
  weddingId  String
  familyName String
  city       String?
  notes      String?
  createdAt  DateTime @default(now())
  wedding    Wedding  @relation(fields: [weddingId], references: [id])
  guests     Guest[]
}

model TaskList {
  id        String   @id @default(cuid())
  weddingId String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  wedding   Wedding  @relation(fields: [weddingId], references: [id])
  tasks     Task[]
}

model Task {
  id          String       @id @default(cuid())
  taskListId  String
  title       String
  category    TaskCategory
  dueDate     DateTime?
  remarks     String?
  addedBy     TaskAddedBy
  completed   Boolean      @default(false)
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  taskList    TaskList     @relation(fields: [taskListId], references: [id], onDelete: Cascade)
  wedding     Wedding?     @relation(fields: [weddingId], references: [id])
  weddingId   String?
}

model Guest {
  id                    String             @id @default(cuid())
  fullName              String
  phone                 String?
  side                  GuestSide          @default(BOTH)
  food                  FoodPreference?
  invitationSent        Boolean            @default(false)
  notes                 String?
  accommodationRequired Boolean            @default(false)
  address               String?
  city                  String?
  createdAt             DateTime           @default(now())
  email                 String?
  familyId              String?
  giftReceived          Boolean            @default(false)
  invitationDelivered   Boolean            @default(false)
  relation              String?
  transportRequired     Boolean            @default(false)
  updatedAt             DateTime           @updatedAt
  weddingId             String
  family                Family?            @relation(fields: [familyId], references: [id])
  wedding               Wedding            @relation(fields: [weddingId], references: [id])
  customValues          GuestCustomValue[]
  events                GuestEvent[]
}

model Event {
  id          String       @id @default(cuid())
  weddingId   String
  wedding     Wedding      @relation(fields: [weddingId], references: [id])
  title       String
  type        EventType
  venue       String?
  description String?
  startTime   DateTime
  endTime     DateTime?
  guests      GuestEvent[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model GuestEvent {
  id        String     @id @default(cuid())
  guestId   String
  eventId   String
  rsvp      RSVPStatus @default(PENDING)
  checkedIn Boolean    @default(false)
  mealTaken Boolean    @default(false)
  createdAt DateTime   @default(now())
  event     Event      @relation(fields: [eventId], references: [id])
  guest     Guest      @relation(fields: [guestId], references: [id])

  @@unique([guestId, eventId])
}

model BudgetItem {
  id           String              @id @default(cuid())
  weddingId    String
  description  String
  category     BudgetCategory
  estimated    Float
  actual       Float?
  paid         Float?
  remarks      String?
  addedBy      BudgetAddedBy       @default(SHUBHAM)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  wedding      Wedding             @relation(fields: [weddingId], references: [id])
  customValues BudgetCustomValue[]
}

model Vendor {
  id        String         @id @default(cuid())
  name      String
  phone     String?
  email     String?
  weddingId String
  address   String?
  createdAt DateTime       @default(now())
  notes     String?
  category  VendorCategory
  wedding   Wedding        @relation(fields: [weddingId], references: [id])
}

model Document {
  id         String   @id @default(cuid())
  weddingId  String
  title      String
  fileUrl    String
  uploadedAt DateTime @default(now())
  wedding    Wedding  @relation(fields: [weddingId], references: [id])
}

model GuestCustomField {
  id        String             @id @default(cuid())
  weddingId String
  name      String
  type      FieldType
  wedding   Wedding            @relation(fields: [weddingId], references: [id])
  values    GuestCustomValue[]
}

model GuestCustomValue {
  id      String           @id @default(cuid())
  guestId String
  fieldId String
  value   String?
  field   GuestCustomField @relation(fields: [fieldId], references: [id])
  guest   Guest            @relation(fields: [guestId], references: [id])

  @@unique([guestId, fieldId])
}

model BudgetCustomField {
  id        String              @id @default(cuid())
  weddingId String
  name      String
  type      FieldType
  wedding   Wedding             @relation(fields: [weddingId], references: [id])
  values    BudgetCustomValue[]
}

model BudgetCustomValue {
  id           String            @id @default(cuid())
  budgetItemId String
  fieldId      String
  value        String?
  budgetItem   BudgetItem        @relation(fields: [budgetItemId], references: [id])
  field        BudgetCustomField @relation(fields: [fieldId], references: [id])

  @@unique([budgetItemId, fieldId])
}

enum UserRole {
  ADMIN
  FAMILY
  VIEWER
}

enum GuestSide {
  BRIDE
  GROOM
  BOTH
}

enum RSVPStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum FoodPreference {
  VEG
  NON_VEG
  JAIN
  VEGAN
}

enum EventType {
  ENGAGEMENT
  HALDI
  MEHENDI
  SANGEET
  WEDDING
  RECEPTION
  COCKTAIL
  OTHER
}

enum VendorCategory {
  VENUE
  CATERING
  DECOR
  PHOTOGRAPHY
  VIDEOGRAPHY
  MUSIC
  HOTEL
  TRANSPORT
  MAKEUP
  OTHER
}

enum BudgetCategory {
  VENUE
  FOOD
  DECOR
  PHOTOGRAPHY
  HOTEL
  TRANSPORT
  GIFTS
  CLOTHES
  JEWELLERY
  OTHER
}

enum FieldType {
  TEXT
  NUMBER
  BOOLEAN
  DATE
  SELECT
}

enum BudgetAddedBy {
  SHUBHAM
  AAKRITI
  MUSKAN
  ANKITA
  SOURAV
}

enum TaskAddedBy {
  SHUBHAM
  AAKRITI
  MUSKAN
  ANKITA
  SOURAV
}

enum TaskCategory {
  GENERAL
  VENUE
  FOOD
  DECOR
  GUEST
  TRAVEL
  DOCUMENT
  PAYMENT
  OTHER
}
