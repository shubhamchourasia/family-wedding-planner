generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  username    String    @unique
  fullName    String
  authId      String?   @unique
  role        UserRole  @default(FAMILY)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  weddings    Wedding[]
}

model Wedding {
  id           String              @id @default(cuid())
  title        String
  brideName    String
  groomName    String
  startDate    DateTime
  endDate      DateTime?
  ownerId      String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  description  String?
  location     String?
  budgets      Budget[]
  budgetFields BudgetCustomField[]
  documents    Document[]
  events       Event[]
  families     Family[]
  guests       Guest[]
  guestFields  GuestCustomField[]
  tasks        Task[]
  vendors      Vendor[]
  owner        User                @relation(fields: [ownerId], references: [id])
}

model Family {
  id         String   @id @default(cuid())
  weddingId  String
  familyName String
  city       String?
  notes      String?
  createdAt  DateTime @default(now())
  wedding    Wedding  @relation(fields: [weddingId], references: [id])
  guests     Guest[]
}

model Guest {
  id                    String             @id @default(cuid())
  fullName              String
  phone                 String?
  side                  GuestSide          @default(BOTH)
  food                  FoodPreference?
  invitationSent        Boolean            @default(false)
  notes                 String?
  accommodationRequired Boolean            @default(false)
  address               String?
  city                  String?
  createdAt             DateTime           @default(now())
  email                 String?
  familyId              String?
  giftReceived          Boolean            @default(false)
  invitationDelivered   Boolean            @default(false)
  relation              String?
  transportRequired     Boolean            @default(false)
  updatedAt             DateTime           @updatedAt
  weddingId             String
  family                Family?            @relation(fields: [familyId], references: [id])
  wedding               Wedding            @relation(fields: [weddingId], references: [id])
  customValues          GuestCustomValue[]
  events                GuestEvent[]
}

model Event {
  id        String       @id @default(cuid())
  title     String
  venue     String?
  startTime DateTime
  endTime   DateTime?
  weddingId String
  createdAt DateTime     @default(now())
  type      EventType
  wedding   Wedding      @relation(fields: [weddingId], references: [id])
  guests    GuestEvent[]
}

model GuestEvent {
  id        String     @id @default(cuid())
  guestId   String
  eventId   String
  rsvp      RSVPStatus @default(PENDING)
  checkedIn Boolean    @default(false)
  mealTaken Boolean    @default(false)
  createdAt DateTime   @default(now())
  event     Event      @relation(fields: [eventId], references: [id])
  guest     Guest      @relation(fields: [guestId], references: [id])

  @@unique([guestId, eventId])
}

model Budget {
  id        String       @id @default(cuid())
  title     String
  weddingId String
  createdAt DateTime     @default(now())
  wedding   Wedding      @relation(fields: [weddingId], references: [id])
  items     BudgetItem[]
}

model BudgetItem {
  id           String              @id @default(cuid())
  description  String
  estimated    Float
  actual       Float?
  paid         Float?
  budgetId     String
  createdAt    DateTime            @default(now())
  vendorId     String?
  category     BudgetCategory
  customValues BudgetCustomValue[]
  budget       Budget              @relation(fields: [budgetId], references: [id])
  vendor       Vendor?             @relation(fields: [vendorId], references: [id])
}

model Vendor {
  id          String         @id @default(cuid())
  name        String
  phone       String?
  email       String?
  weddingId   String
  address     String?
  createdAt   DateTime       @default(now())
  notes       String?
  category    VendorCategory
  budgetItems BudgetItem[]
  wedding     Wedding        @relation(fields: [weddingId], references: [id])
}

model Task {
  id          String       @id @default(cuid())
  title       String
  completed   Boolean      @default(false)
  dueDate     DateTime?
  weddingId   String
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  description String?
  priority    TaskPriority @default(MEDIUM)
  wedding     Wedding      @relation(fields: [weddingId], references: [id])
}

model Document {
  id         String   @id @default(cuid())
  weddingId  String
  title      String
  fileUrl    String
  uploadedAt DateTime @default(now())
  wedding    Wedding  @relation(fields: [weddingId], references: [id])
}

model GuestCustomField {
  id        String             @id @default(cuid())
  weddingId String
  name      String
  type      FieldType
  wedding   Wedding            @relation(fields: [weddingId], references: [id])
  values    GuestCustomValue[]
}

model GuestCustomValue {
  id      String           @id @default(cuid())
  guestId String
  fieldId String
  value   String?
  field   GuestCustomField @relation(fields: [fieldId], references: [id])
  guest   Guest            @relation(fields: [guestId], references: [id])

  @@unique([guestId, fieldId])
}

model BudgetCustomField {
  id        String              @id @default(cuid())
  weddingId String
  name      String
  type      FieldType
  wedding   Wedding             @relation(fields: [weddingId], references: [id])
  values    BudgetCustomValue[]
}

model BudgetCustomValue {
  id           String            @id @default(cuid())
  budgetItemId String
  fieldId      String
  value        String?
  budgetItem   BudgetItem        @relation(fields: [budgetItemId], references: [id])
  field        BudgetCustomField @relation(fields: [fieldId], references: [id])

  @@unique([budgetItemId, fieldId])
}

enum UserRole {
  ADMIN
  FAMILY
  VIEWER
}

enum GuestSide {
  BRIDE
  GROOM
  BOTH
}

enum RSVPStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum FoodPreference {
  VEG
  NON_VEG
  JAIN
  VEGAN
}

enum EventType {
  ENGAGEMENT
  HALDI
  MEHENDI
  SANGEET
  WEDDING
  RECEPTION
  COCKTAIL
  OTHER
}

enum VendorCategory {
  VENUE
  CATERING
  DECOR
  PHOTOGRAPHY
  VIDEOGRAPHY
  MUSIC
  HOTEL
  TRANSPORT
  MAKEUP
  OTHER
}

enum BudgetCategory {
  VENUE
  FOOD
  DECOR
  PHOTOGRAPHY
  HOTEL
  TRANSPORT
  GIFTS
  CLOTHES
  JEWELLERY
  OTHER
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum FieldType {
  TEXT
  NUMBER
  BOOLEAN
  DATE
  SELECT
}
